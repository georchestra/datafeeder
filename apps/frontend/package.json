{
  "name": "@datakern/frontend",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --serve-path /frontend/",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "generate-api": "ng-openapi-gen",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,html,css,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css,scss,json}\"",
    "test:ut": "vitest",
    "test:ut:ci": "vitest --run",
    "test:e2e": "ng serve --port 4201 & cypress open",
    "test:e2e:ci": "ng serve --port 4201 & cypress run"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~20.3.0",
    "@angular/common": "~20.3.0",
    "@angular/compiler": "~20.3.0",
    "@angular/core": "~20.3.0",
    "@angular/forms": "~20.3.0",
    "@angular/platform-browser": "~20.3.0",
    "@angular/router": "~20.3.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@tailwindcss/vite": "^4.1.17",
    "postcss": "^8.5.6",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.17"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.1.0",
    "@analogjs/vitest-angular": "^2.1.0",
    "@angular-devkit/core": "~20.3.0",
    "@angular-devkit/schematics": "~20.3.0",
    "@angular/build": "~20.3.0",
    "@angular/cdk": "~20.2.0",
    "@angular/cli": "~20.3.0",
    "@angular/compiler-cli": "~20.3.0",
    "@angular/language-service": "~20.3.0",
    "@angular/material": "~20.2.0",
    "@eslint/js": "^9.8.0",
    "@schematics/angular": "~20.3.0",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/node": "20.19.9",
    "@typescript-eslint/utils": "^8.40.0",
    "@vitest/coverage-v8": "^3.1.1",
    "@vitest/ui": "^3.1.1",
    "angular-eslint": "^20.3.0",
    "cypress": "^15.6.0",
    "cypress-browser-permissions": "^1.1.0",
    "cypress-real-events": "^1.15.0",
    "cypress-terminal-report": "^7.3.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-cypress": "^3.5.0",
    "jsdom": "~22.1.0",
    "ng-openapi-gen": "^1.0.5",
    "prettier": "^2.6.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^7.0.0",
    "vitest": "^3.1.1"
  }
}
