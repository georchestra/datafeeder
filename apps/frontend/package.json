{
  "name": "@datakern/frontend",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --serve-path /datakern/",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "generate-api": "ng-openapi-gen",
    "i18n:extract": "ngx-translate-extract -s --fi '  ' --input ./src --output ./translations/{en,de,fr,it,es,nl,pt,sk}.json --clean --format json && npm run format",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,html,css,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css,scss,json}\"",
    "test:ut": "vitest",
    "test:ut:ci": "vitest --run",
    "test:e2e": "ng serve --port 4201 & cypress open",
    "test:e2e:ci": "ng serve --port 4201 & cypress run"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "20.3.15",
    "@angular/cdk": "20.2.14",
    "@angular/common": "20.3.15",
    "@angular/compiler": "20.3.15",
    "@angular/core": "20.3.16",
    "@angular/elements": "20.3.15",
    "@angular/forms": "20.3.15",
    "@angular/material": "20.2.14",
    "@angular/material-moment-adapter": "20.2.14",
    "@angular/platform-browser": "20.3.15",
    "@angular/platform-browser-dynamic": "20.3.15",
    "@angular/platform-server": "20.3.15",
    "@angular/router": "20.3.15",
    "@biesbjerg/ngx-translate-extract-marker": "~1.0.0",
    "@ngrx/component": "20.1.0",
    "@ngrx/effects": "20.1.0",
    "@ngrx/operators": "20.1.0",
    "@ngrx/router-store": "20.1.0",
    "@ngrx/schematics": "20.1.0",
    "@ngrx/store": "20.1.0",
    "@ngrx/store-devtools": "20.1.0",
    "@ngx-translate/core": "~16.0.4",
    "@ngx-translate/http-loader": "~16.0.1",
    "geonetwork-ui": "2.8.0-dev.5b3b50fcc",
    "rxjs": "~7.8.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.1.0",
    "@analogjs/vitest-angular": "^2.1.0",
    "@angular-devkit/core": "20.3.12",
    "@angular-devkit/schematics": "20.3.12",
    "@angular/build": "20.3.12",
    "@angular/cli": "20.3.15",
    "@angular/compiler-cli": "20.3.15",
    "@angular/language-service": "20.3.15",
    "@eslint/js": "^9.8.0",
    "@schematics/angular": "~20.3.0",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/geojson": "^7946.0.7",
    "@types/node": "20.19.9",
    "@typescript-eslint/utils": "^8.40.0",
    "@vendure/ngx-translate-extract": "~10.1.1",
    "@vitest/coverage-v8": "^3.1.1",
    "@vitest/ui": "^3.1.1",
    "angular-eslint": "^20.3.0",
    "autoprefixer": "^10.4.22",
    "cypress": "^15.6.0",
    "cypress-browser-permissions": "^1.1.0",
    "cypress-real-events": "^1.15.0",
    "cypress-terminal-report": "^7.3.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-cypress": "^3.5.0",
    "jsdom": "~22.1.0",
    "ng-openapi-gen": "^1.0.5",
    "ngx-translate-testing": "^6.1.0",
    "postcss": "^8.5.6",
    "prettier": "^2.6.2",
    "tailwindcss": "^3.3.3",
    "tslib": "^2.3.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.40.0",
    "vite": "^7.0.0",
    "vitest": "^3.1.1"
  }
}
