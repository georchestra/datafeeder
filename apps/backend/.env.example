# Airflow Configuration
# Default: direct connection to Airflow API (for local development with make run-backend)
# This bypasses the gateway's authentication layer
AIRFLOW_HOST=http://localhost:8081/airflow
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow

# Alternative: direct connection from within Docker
# AIRFLOW_HOST=http://airflow-apiserver:8081/airflow
