# Used to override default values in config.py
BACKEND_INTERNAL_URL=http://datafeeder-backend:8000
AIRFLOW_INTERNAL_URL=http://${AIRFLOW_HOST}:8081/airflow
ENCRYPTION_KEY=your_encryption_key
POSTGRES_DATA_HOST=datadb
POSTGRES_DATA_PORT=5432
POSTGRES_DATA_USER=postgres
POSTGRES_DATA_PASSWORD=mypassword
POSTGRES_DATA_DB=postgres
# In local dev the source DB reuses the same PostgreSQL instance as the data DB.
# In production this should point to a separate external source database.
# The key (SOURCE_DB_1) must match the Airflow connection name in airflow/files/conn.json.
SOURCE_DATABASES={"SOURCE_DB_1": "postgresql://postgres:mypassword@datadb:5432/postgres"}
